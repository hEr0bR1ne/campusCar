<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="diffbot" params="prefix">

    <!-- Robot dimensions -->
    <xacro:property name="PI"            value="3.1415926535897931"/>
    <xacro:property name="base_mass"     value="10.0"/>
    <xacro:property name="base_length"   value="0.60"/>   <!-- front-to-rear: 600mm -->
    <xacro:property name="base_width"    value="0.45"/>   <!-- left-to-right: 450mm -->
    <xacro:property name="base_height"   value="0.10"/>

    <!-- Wheel dimensions (hoverboard wheel) -->
    <xacro:property name="wheel_mass"    value="1.5"/>
    <xacro:property name="wheel_radius"  value="0.0825"/>  <!-- 82.5mm -->
    <xacro:property name="wheel_len"     value="0.055"/>   <!-- tyre width -->

    <!-- Wheel positions -->
    <!-- Axle offset from body center along X: wheelbase/2 = 400mm/2 = 200mm -->
    <xacro:property name="axle_offset_x" value="0.20"/>
    <!-- Lateral offset: wheel center at body edge -->
    <xacro:property name="axle_offset_y" value="${base_width / 2.0}"/>
    <!-- Wheel bottom touches ground when base_link is at wheel_radius height -->
    <xacro:property name="axle_offset_z" value="0.0"/>

    <!-- ==================== Base Link ==================== -->
    <link name="${prefix}base_link">
      <collision>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <material name="orange"/>
      </visual>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${base_mass}"/>
        <inertia
          ixx="${base_mass / 12.0 * (base_width*base_width   + base_height*base_height)}" ixy="0" ixz="0"
          iyy="${base_mass / 12.0 * (base_length*base_length + base_height*base_height)}" iyz="0"
          izz="${base_mass / 12.0 * (base_length*base_length + base_width*base_width)}"/>
      </inertial>
    </link>

    <!-- ==================== Wheel macro ==================== -->
    <xacro:macro name="wheel" params="prefix side lr_reflect fb_reflect fb_label">
      <joint name="${prefix}${fb_label}_${side}_wheel_joint" type="continuous">
        <parent link="${prefix}base_link"/>
        <child  link="${prefix}${fb_label}_${side}_wheel"/>
        <!-- x: front(+) or rear(-); y: left(+) or right(-); z: axle height -->
        <origin xyz="${fb_reflect * axle_offset_x}
                     ${lr_reflect * axle_offset_y}
                     ${axle_offset_z}"
                rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.2"/>
      </joint>

      <link name="${prefix}${fb_label}_${side}_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
          <material name="black"/>
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0" ixz="0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0"
            izz="${wheel_mass / 2.0  *  wheel_radius*wheel_radius}"/>
        </inertial>
      </link>
    </xacro:macro>

    <!-- ==================== Four wheels ==================== -->
    <xacro:wheel prefix="${prefix}" side="left"  lr_reflect=" 1" fb_reflect=" 1" fb_label="front"/>
    <xacro:wheel prefix="${prefix}" side="right" lr_reflect="-1" fb_reflect=" 1" fb_label="front"/>
    <xacro:wheel prefix="${prefix}" side="left"  lr_reflect=" 1" fb_reflect="-1" fb_label="rear"/>
    <xacro:wheel prefix="${prefix}" side="right" lr_reflect="-1" fb_reflect="-1" fb_label="rear"/>

  </xacro:macro>

</robot>
