# ============================================================
# Hardware profile: Hikrobot MV-CS016-10GC camera bringup
# ============================================================
#
# This is an arrival-day camera test profile. It starts the Hikrobot GigE
# camera through camera_aravis2 and skips automatic chassis startup.

ROBOT_NAME="hikrobot_gige"
ROBOT_DESCRIPTION="Hikrobot MV-CS016-10GC GigE Vision camera test profile"

# Chassis is intentionally skipped here. Copy template.env for a real car
# profile once the STM32 UART chassis protocol is confirmed.
CHASSIS_ADAPTER="none"
CHASSIS_START_MODE="skip"
CHASSIS_REQUIRED="0"

CMD_VEL_TOPIC="${CMD_VEL_TOPIC:-/cmd_vel}"
FIX_TOPIC="${FIX_TOPIC:-/fix}"
HEADING_TOPIC="${HEADING_TOPIC:-/heading}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/color/image_raw}"
CAMERA_INFO_TOPIC="${CAMERA_INFO_TOPIC:-/camera/color/camera_info}"
IMAGE_TOPIC_ALIASES="${IMAGE_TOPIC_ALIASES:-}"

CAMERA_ADAPTER="hikrobot_mv_cs016_10gc_aravis"
CAMERA_DEPENDENCY_MODE="hikrobot_aravis"
CAMERA_START_MODE="command"
CAMERA_DRIVER_LABEL="Hikrobot MV-CS016-10GC"
CAMERA_LAUNCH_CMD="${CAMERA_LAUNCH_CMD:-${CAMPUSCAR_ROOT}/scripts/hikrobot_camera_start.sh}"
CAMERA_PROCESS_PATTERN="${CAMERA_PROCESS_PATTERN:-[c]amera_driver_gv}"
CAMERA_USB_RESET_IDS="${CAMERA_USB_RESET_IDS:-}"

CAMERA_SETUP_FILES=()
CAMERA_STOP_PATTERNS=(
    "[c]amera_driver_gv"
)

