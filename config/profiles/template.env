# ============================================================
# Hardware profile template
# ============================================================
#
# Copy this file to config/profiles/<new_robot>.env and fill only the
# hardware-specific pieces. Common UE/RTK/video behavior stays in
# config/robot.env and the startup scripts.

ROBOT_NAME="new_robot"
ROBOT_DESCRIPTION="Describe chassis and camera here"

# Chassis adapter
# Modes:
#   ssh_ros2       NUC SSHes into the chassis and starts ROS2 there.
#   local_command  NUC starts a local command for the chassis driver.
#   skip           Do not start chassis automatically.
CHASSIS_ADAPTER="replace_me"
CHASSIS_START_MODE="ssh_ros2"
CHASSIS_REQUIRED="1"
CAR_IP="${CAR_IP:-192.168.100.2}"
CAR_USER="${CAR_USER:-robot}"
CAR_PASS="${CAR_PASS:-}"
CAR_LAUNCH_CMD="${CAR_LAUNCH_CMD:-source ~/ros2_ws/install/setup.bash && ros2 launch <pkg> <launch>.py}"
LOCAL_CHASSIS_LAUNCH_CMD="${LOCAL_CHASSIS_LAUNCH_CMD:-}"
CHASSIS_NODE_CHECK_PATTERN="${CHASSIS_NODE_CHECK_PATTERN:-base_control}"
CHASSIS_NODE_CHECK_CMD="${CHASSIS_NODE_CHECK_CMD:-}"
CHASSIS_LOG_FILE="${CHASSIS_LOG_FILE:-~/ros2_chassis.log}"

# ROS topics provided by this vehicle
CMD_VEL_TOPIC="${CMD_VEL_TOPIC:-/cmd_vel}"
FIX_TOPIC="${FIX_TOPIC:-/fix}"
HEADING_TOPIC="${HEADING_TOPIC:-/heading}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/color/image_raw}"
IMAGE_TOPIC_ALIASES="${IMAGE_TOPIC_ALIASES:-}"

# Camera adapter
# Modes:
#   ros2_launch  Use ros2 launch <package> <launch_file> ${CAMERA_LAUNCH_ARGS[@]}.
#   command      Use CAMERA_LAUNCH_CMD.
#   skip         Do not start camera automatically.
CAMERA_ADAPTER="replace_me"
CAMERA_DEPENDENCY_MODE="custom"
CAMERA_START_MODE="ros2_launch"
CAMERA_DRIVER_LABEL="New camera"
CAMERA_LAUNCH_PACKAGE="<camera_pkg>"
CAMERA_LAUNCH_FILE="<camera_launch>.py"
CAMERA_LAUNCH_CMD="${CAMERA_LAUNCH_CMD:-}"
CAMERA_PROCESS_PATTERN="<camera_process_or_launch_name>"
CAMERA_USB_RESET_IDS="${CAMERA_USB_RESET_IDS:-}"

CAMERA_SETUP_FILES=(
    # "/path/to/camera_ws/install/setup.bash"
)
CAMERA_STOP_PATTERNS=(
    "<camera_process_or_launch_name>"
)
CAMERA_LAUNCH_ARGS=(
    # "param_name:=value"
)
