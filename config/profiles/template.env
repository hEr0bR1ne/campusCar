# ============================================================
# Hardware profile template
# ============================================================
#
# Copy this file to config/profiles/<new_robot>.env and fill only the
# hardware-specific pieces. Common UE/RTK/video behavior stays in
# config/robot.env and the startup scripts.

ROBOT_NAME="new_stm32_robot"
ROBOT_DESCRIPTION="Direct NUC-to-STM32 chassis and GigE camera profile"

# Chassis adapter
# Modes:
#   local_command  NUC starts a local command for the chassis driver.
#   skip           Do not start chassis automatically.
CHASSIS_ADAPTER="stm32_hoverboard_uart_ros2_control"
CHASSIS_DEPENDENCY_MODE="hoverboard_ros2_control"
CHASSIS_START_MODE="local_command"
CHASSIS_REQUIRED="1"
LOCAL_CHASSIS_LAUNCH_CMD="${LOCAL_CHASSIS_LAUNCH_CMD:-${CAMPUSCAR_ROOT}/scripts/stm32_hoverboard_start.sh}"
CHASSIS_NODE_CHECK_PATTERN="${CHASSIS_NODE_CHECK_PATTERN:-controller_manager}"
CHASSIS_NODE_CHECK_CMD="${CHASSIS_NODE_CHECK_CMD:-}"
CHASSIS_LOG_FILE="${CHASSIS_LOG_FILE:-${CAMPUSCAR_ROOT}/data/logs/chassis.log}"
CHASSIS_PROCESS_PATTERN="${CHASSIS_PROCESS_PATTERN:-[r]os2_control_node|[r]obot_state_publisher|[s]pawner.*hoverboard_base_controller|[s]pawner.*joint_state_broadcaster}"

HOVERBOARD_FRONT_DEVICE="${HOVERBOARD_FRONT_DEVICE:-/dev/serial/by-id/<front-driver>}"
HOVERBOARD_REAR_DEVICE="${HOVERBOARD_REAR_DEVICE:-/dev/serial/by-id/<rear-driver>}"
HOVERBOARD_FEEDBACK_FORMAT="${HOVERBOARD_FEEDBACK_FORMAT:-compact}"
HOVERBOARD_COMMAND_LIMIT_RPM="${HOVERBOARD_COMMAND_LIMIT_RPM:-50}"
CHASSIS_SETUP_FILES=(
    "$HOVERBOARD_SETUP"
)
CHASSIS_STOP_PATTERNS=(
    "[r]os2_control_node"
    "[r]obot_state_publisher"
    "[s]pawner.*hoverboard_base_controller"
    "[s]pawner.*joint_state_broadcaster"
)

# ROS topics provided by this vehicle
CMD_VEL_TOPIC="${CMD_VEL_TOPIC:-/cmd_vel}"
FIX_TOPIC="${FIX_TOPIC:-/fix}"
HEADING_TOPIC="${HEADING_TOPIC:-/heading}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/color/image_raw}"
IMAGE_TOPIC_ALIASES="${IMAGE_TOPIC_ALIASES:-}"

# Camera adapter
# Modes:
#   ros2_launch  Use ros2 launch <package> <launch_file> ${CAMERA_LAUNCH_ARGS[@]}.
#   command      Use CAMERA_LAUNCH_CMD.
#   skip         Do not start camera automatically.
CAMERA_ADAPTER="hikrobot_gige_aravis"
CAMERA_DEPENDENCY_MODE="hikrobot_aravis"
CAMERA_START_MODE="command"
CAMERA_DRIVER_LABEL="Hikrobot GigE camera"
CAMERA_LAUNCH_PACKAGE=""
CAMERA_LAUNCH_FILE=""
CAMERA_LAUNCH_CMD="${CAMERA_LAUNCH_CMD:-${CAMPUSCAR_ROOT}/scripts/hikrobot_camera_start.sh}"
CAMERA_PROCESS_PATTERN="[c]amera_driver_gv"
CAMERA_USB_RESET_IDS="${CAMERA_USB_RESET_IDS:-}"

CAMERA_SETUP_FILES=()
CAMERA_STOP_PATTERNS=(
    "[c]amera_driver_gv"
)
CAMERA_LAUNCH_ARGS=()
