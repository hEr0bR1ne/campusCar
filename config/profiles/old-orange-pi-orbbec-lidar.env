# ============================================================
# 车型 Profile 覆盖层：旧底盘 + Livox Mid360 激光雷达避障
# 在 old-orange-pi-orbbec 基础上添加激光雷达和避障配置
#
# 使用方式：
#   CAR_PROFILE=old-orange-pi-orbbec-lidar ./scripts/launch_all.sh
#   然后：./scripts/lidar_start.sh
# ============================================================

# ── 先加载原始 profile ────────────────────────────────────
CAMPUSCAR_PROFILE_DIR="${CAMPUSCAR_PROFILE_DIR:-$(dirname "${BASH_SOURCE[0]}")}"
source "${CAMPUSCAR_PROFILE_DIR}/old-orange-pi-orbbec.env"

# ── 覆盖车型标识 ──────────────────────────────────────────
CAR_PROFILE_NAME="旧底盘 OrangePi + Orbbec + Livox Mid360 避障"

# ── 关键：将控制节点输出重定向到 /cmd_vel_input ───────────
# obstacle_stopper.py 订阅此话题，仲裁后输出到 /cmd_vel
# 这样现有控制节点（web_gui/ue_bridge/car_gui）零修改
CMD_VEL_TOPIC="/cmd_vel_input"

# ── Livox Mid360 网络配置 ─────────────────────────────────
# Mid360 默认 IP（出厂设置）
LIVOX_LIDAR_IP="${LIVOX_LIDAR_IP:-192.168.1.177}"
# NUC 连接 Mid360 的网卡 IP（需与 Mid360 同网段）
LIVOX_HOST_IP="${LIVOX_HOST_IP:-192.168.1.2}"
LIVOX_HOST_NETMASK="${LIVOX_HOST_NETMASK:-24}"
# 连接 Mid360 的网卡名（留空则由容器内 entrypoint 跳过，需宿主机预先配置）
LIVOX_NET_IFACE="${LIVOX_NET_IFACE:-}"
# 点云发布频率（Hz）
LIVOX_PUBLISH_FREQ="${LIVOX_PUBLISH_FREQ:-10.0}"

# ── 点云转 LaserScan 参数 ─────────────────────────────────
# 垂直高度过滤（米），过滤地面和高处噪点
SCAN_MIN_HEIGHT="${SCAN_MIN_HEIGHT:--0.3}"
SCAN_MAX_HEIGHT="${SCAN_MAX_HEIGHT:-0.3}"
# 距离范围（米）
SCAN_RANGE_MIN="${SCAN_RANGE_MIN:-0.1}"
SCAN_RANGE_MAX="${SCAN_RANGE_MAX:-50.0}"

# ── Mid360 安装位置（相对于 base_link，单位：米/弧度）────
LIDAR_X="${LIDAR_X:-0.0}"
LIDAR_Y="${LIDAR_Y:-0.0}"
LIDAR_Z="${LIDAR_Z:-0.2}"    # 安装高度约 0.2m
LIDAR_ROLL="${LIDAR_ROLL:-0.0}"
LIDAR_PITCH="${LIDAR_PITCH:-0.0}"
LIDAR_YAW="${LIDAR_YAW:-0.0}"

# ── 避障仲裁参数 ──────────────────────────────────────────
# 刹停距离（米）：前方障碍物距离小于此值时刹停
OBSTACLE_STOP_DIST="${OBSTACLE_STOP_DIST:-0.5}"
# 减速距离（米）：前方障碍物距离小于此值时开始减速
OBSTACLE_WARN_DIST="${OBSTACLE_WARN_DIST:-3.0}"
# 前方检测扇区半角（度）：检测前方 ±N° 范围内的障碍物
OBSTACLE_FRONT_ANGLE_DEG="${OBSTACLE_FRONT_ANGLE_DEG:-30}"
# 是否启用避障（0=禁用，完全透传；1=启用）
OBSTACLE_ENABLED="${OBSTACLE_ENABLED:-1}"
# /scan 超时时间（秒）：超时后退化为透传模式
OBSTACLE_SCAN_TIMEOUT="${OBSTACLE_SCAN_TIMEOUT:-2.0}"
# 避障节点发布频率（Hz）
OBSTACLE_PUBLISH_RATE_HZ="${OBSTACLE_PUBLISH_RATE_HZ:-20.0}"
