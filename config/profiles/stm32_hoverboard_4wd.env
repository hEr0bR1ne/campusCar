# ============================================================
# Hardware profile: STM32 UART 4WD chassis + Hikrobot GigE camera
# ============================================================
#
# Seller-confirmed chassis facts:
#   - Two 5V TTL UART links: front driver and rear driver.
#   - Serial settings: 115200 baud, 8N1, RX/TX/GND.
#   - Command frame: 0xABCD, int16 steer, int16 speed, uint16 XOR checksum.
#   - Arrival-day safe command scale: keep speed/steer limited to 50 RPM.

ROBOT_NAME="stm32_hoverboard_4wd"
ROBOT_DESCRIPTION="Direct NUC-to-STM32 4WD chassis over dual UART, Hikrobot MV-CS016-10GC camera"

# Chassis adapter
CHASSIS_ADAPTER="stm32_hoverboard_uart_ros2_control"
CHASSIS_DEPENDENCY_MODE="hoverboard_ros2_control"
CHASSIS_START_MODE="local_command"
CHASSIS_REQUIRED="1"
LOCAL_CHASSIS_LAUNCH_CMD="${LOCAL_CHASSIS_LAUNCH_CMD:-${CAMPUSCAR_ROOT}/scripts/stm32_hoverboard_start.sh}"
CHASSIS_PROCESS_PATTERN="${CHASSIS_PROCESS_PATTERN:-[r]os2_control_node|[r]obot_state_publisher|[s]pawner.*hoverboard_base_controller|[s]pawner.*joint_state_broadcaster}"
CHASSIS_NODE_CHECK_PATTERN="${CHASSIS_NODE_CHECK_PATTERN:-controller_manager}"
CHASSIS_LOG_FILE="${CHASSIS_LOG_FILE:-${CAMPUSCAR_ROOT}/data/logs/chassis.log}"

HOVERBOARD_FRONT_DEVICE="${HOVERBOARD_FRONT_DEVICE:-/dev/ttyUSB0}"
HOVERBOARD_REAR_DEVICE="${HOVERBOARD_REAR_DEVICE:-/dev/ttyUSB1}"
HOVERBOARD_FEEDBACK_FORMAT="${HOVERBOARD_FEEDBACK_FORMAT:-compact}"
HOVERBOARD_WHEEL_RADIUS="${HOVERBOARD_WHEEL_RADIUS:-0.0825}"
HOVERBOARD_MAX_VELOCITY="${HOVERBOARD_MAX_VELOCITY:-0.30}"
HOVERBOARD_COMMAND_LIMIT_RPM="${HOVERBOARD_COMMAND_LIMIT_RPM:-50}"

CHASSIS_SETUP_FILES=("$HOVERBOARD_SETUP")
CHASSIS_STOP_PATTERNS=(
    "[r]os2_control_node"
    "[r]obot_state_publisher"
    "[s]pawner.*hoverboard_base_controller"
    "[s]pawner.*joint_state_broadcaster"
)

# ROS topics exposed by this chassis/camera stack
CMD_VEL_TOPIC="${CMD_VEL_TOPIC:-/cmd_vel}"
FIX_TOPIC="${FIX_TOPIC:-/fix}"
HEADING_TOPIC="${HEADING_TOPIC:-/heading}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/color/image_raw}"
CAMERA_INFO_TOPIC="${CAMERA_INFO_TOPIC:-/camera/color/camera_info}"
IMAGE_TOPIC_ALIASES="${IMAGE_TOPIC_ALIASES:-}"

# Conservative arrival-day movement limits. Increase only after wheels-off-ground
# and low-speed floor tests confirm the RPM scaling.
MAX_LINEAR_SPEED="${MAX_LINEAR_SPEED:-0.30}"
MAX_ANGULAR_SPEED="${MAX_ANGULAR_SPEED:-0.60}"
DEFAULT_LINEAR_SPEED="${DEFAULT_LINEAR_SPEED:-0.10}"
DEFAULT_ANGULAR_SPEED="${DEFAULT_ANGULAR_SPEED:-0.20}"
TANK_TURN_MODE="${TANK_TURN_MODE:-angular}"

# Camera adapter
CAMERA_ADAPTER="hikrobot_mv_cs016_10gc_aravis"
CAMERA_DEPENDENCY_MODE="hikrobot_aravis"
CAMERA_START_MODE="command"
CAMERA_DRIVER_LABEL="Hikrobot MV-CS016-10GC"
CAMERA_LAUNCH_CMD="${CAMERA_LAUNCH_CMD:-${CAMPUSCAR_ROOT}/scripts/hikrobot_camera_start.sh}"
CAMERA_PROCESS_PATTERN="${CAMERA_PROCESS_PATTERN:-[c]amera_driver_gv}"
CAMERA_USB_RESET_IDS="${CAMERA_USB_RESET_IDS:-}"
CAMERA_REUSE_PROBE_TIMEOUT="${CAMERA_REUSE_PROBE_TIMEOUT:-2}"
CAMERA_FIRST_FRAME_TIMEOUT="${CAMERA_FIRST_FRAME_TIMEOUT:-5}"

CAMERA_SETUP_FILES=()
CAMERA_STOP_PATTERNS=(
    "[c]amera_driver_gv"
)
