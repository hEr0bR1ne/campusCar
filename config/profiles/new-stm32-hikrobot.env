# ============================================================
# 车型 Profile：新底盘
#   NUC 直连 STM32 串口底盘 + 海康 MV-CS016-10GC GigE 相机
#
# 注意：launch_all.sh 的 direct_uart 启动流程尚未实现，
#       当前切换到此 profile 会在底盘启动步骤保护性退出。
# ============================================================

# ── 车型标识 ──────────────────────────────────────────────
CAR_PROFILE_NAME="新底盘 STM32 + Hikrobot"
CAR_CHASSIS_MODE="direct_uart"

# ── 底盘串口 ──────────────────────────────────────────────
CAR_BASE_TYPE="stm32_hoverboard_4wd"
CAR_SERIAL_PORT="${CAR_SERIAL_PORT:-/dev/ttyUSB0}"
CAR_SERIAL_BAUD="${CAR_SERIAL_BAUD:-115200}"

# ── 速度限制 ──────────────────────────────────────────────
MAX_LINEAR_SPEED=1.0
MAX_ANGULAR_SPEED=1.0
DEFAULT_LINEAR_SPEED=0.3
DEFAULT_ANGULAR_SPEED=0.5
TANK_TURN_MODE=angular
TANK_TURN_SIDE_SPEED_SCALE=1.0
TANK_TURN_MIN_SIDE_SPEED=0.10
TANK_TURN_MAX_SIDE_SPEED=1.0

# ── 车辆姿态校准 ──────────────────────────────────────────
VEHICLE_HEADING_OFFSET_DEG=0.0

# ── RTK 位置保持 ──────────────────────────────────────────
RTK_POSITION_HOLD_ENABLED=1
RTK_POSITION_HOLD_SPEED_THRESHOLD_MPS=0.03
RTK_POSITION_HOLD_ODOM_TIMEOUT_SEC=2.0

# ── UE 运动控制参数 ───────────────────────────────────────
UE_DIRECTION_RATE_HZ=10
UE_DIRECTION_TIMEOUT_SEC=0.8
UE_NAV_RATE_HZ=10
UE_ARRIVE_THRESHOLD_M=0.5
UE_HEADING_KP=1.2
UE_HEADING_TOLERANCE=0.15

# ── UE 速度闭环 ───────────────────────────────────────────
UE_SPEED_KP=0.8
UE_SPEED_KI=0.3
UE_SPEED_ODOM_TIMEOUT=1.0
UE_NAV_MIN_SPEED=0.08
UE_NAV_DECEL_DIST=1.5

# ── 相机：海康 MV-CS016-10GC / camera_aravis2 ─────────────
CAMERA_MODE="hikrobot_gige_aravis"
HIKROBOT_CAMERA_GUID="${HIKROBOT_CAMERA_GUID:-}"
HIKROBOT_CAMERA_NODE="${HIKROBOT_CAMERA_NODE:-hikrobot_camera}"
HIKROBOT_FRAME_ID="${HIKROBOT_FRAME_ID:-hikrobot_camera}"
HIKROBOT_PIXEL_FORMAT="${HIKROBOT_PIXEL_FORMAT:-BGR8}"
HIKROBOT_WIDTH="${HIKROBOT_WIDTH:-1440}"
HIKROBOT_HEIGHT="${HIKROBOT_HEIGHT:-1080}"
HIKROBOT_FPS="${HIKROBOT_FPS:-30.0}"
HIKROBOT_EXPOSURE_AUTO="${HIKROBOT_EXPOSURE_AUTO:-Continuous}"
HIKROBOT_GAIN_AUTO="${HIKROBOT_GAIN_AUTO:-Continuous}"
HIKROBOT_GEV_PACKET_SIZE="${HIKROBOT_GEV_PACKET_SIZE:-}"
HIKROBOT_VERBOSE="${HIKROBOT_VERBOSE:-false}"

# ── rosbridge / RTK ───────────────────────────────────────
ROSBRIDGE_WS="${ROSBRIDGE_WS:-${CAMPUSCAR_ROOT}/src/rtk_tools/rosbridge_ts}"
ROSBRIDGE_SETUP="${ROSBRIDGE_SETUP:-${ROSBRIDGE_WS}/install/setup.bash}"
RTK_BAUD=115200
