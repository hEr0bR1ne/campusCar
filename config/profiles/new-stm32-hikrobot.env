# 新底盘预设：NUC 直连 STM32 串口底盘，海康 GigE 相机
# 当前仅建立 profile 配置入口；launch_all.sh 尚未接入 direct_uart 启动流程。

CAR_PROFILE_NAME="新底盘 STM32 + Hikrobot"
CAR_CHASSIS_MODE="direct_uart"
CAMERA_MODE="hikrobot_gige_aravis"
CAR_BASE_TYPE="stm32_hoverboard_4wd"

# 新底盘预留参数，后续接入串口驱动时复用。
CAR_SERIAL_PORT="${CAR_SERIAL_PORT:-/dev/ttyUSB0}"
CAR_SERIAL_BAUD="${CAR_SERIAL_BAUD:-115200}"