# ============================================================
# 车型 Profile：旧底盘
#   NUC -> Orange Pi -> 底盘（4WD）+ Orbbec 深度相机
# ============================================================

# ── 车型标识 ──────────────────────────────────────────────
CAR_PROFILE_NAME="旧底盘 OrangePi + Orbbec"
CAR_CHASSIS_MODE="remote_ssh"

# ── 底盘网络 ──────────────────────────────────────────────
CAR_IP="192.168.100.2"
CAR_USER="bingda"
CAR_PASS="bingda"
SUDO_PASS="1"
CAR_BASE_TYPE="4WD"
CAR_LAUNCH_CMD="export BASE_TYPE=${CAR_BASE_TYPE}; source ~/ros2_ws/install/setup.bash && ros2 launch base_control_ros2 base_control.launch.py"

# ── 速度限制 ──────────────────────────────────────────────
MAX_LINEAR_SPEED=1.0
MAX_ANGULAR_SPEED=1.0
DEFAULT_LINEAR_SPEED=0.3
DEFAULT_ANGULAR_SPEED=0.5
TANK_TURN_MODE=angular
TANK_TURN_SIDE_SPEED_SCALE=1.0
TANK_TURN_MIN_SIDE_SPEED=0.10
TANK_TURN_MAX_SIDE_SPEED=1.0

# ── 车辆姿态校准 ──────────────────────────────────────────
# GUI 里的"设为正北"按钮会更新这个值；正北在 ENU 坐标里是 90°。
VEHICLE_HEADING_OFFSET_DEG=56.9

# ── RTK 位置保持 ──────────────────────────────────────────
RTK_POSITION_HOLD_ENABLED=1
RTK_POSITION_HOLD_SPEED_THRESHOLD_MPS=0.03
RTK_POSITION_HOLD_ODOM_TIMEOUT_SEC=2.0

# ── UE 运动控制参数 ───────────────────────────────────────
UE_DIRECTION_RATE_HZ=10
UE_DIRECTION_TIMEOUT_SEC=0.8
UE_NAV_RATE_HZ=10
UE_ARRIVE_THRESHOLD_M=0.5
UE_HEADING_KP=1.2
UE_HEADING_TOLERANCE=0.15

# ── UE 速度闭环 ───────────────────────────────────────────
UE_SPEED_KP=0.8
UE_SPEED_KI=0.3
UE_SPEED_ODOM_TIMEOUT=1.0
UE_NAV_MIN_SPEED=0.08
UE_NAV_DECEL_DIST=1.5

# ── 相机 ──────────────────────────────────────────────────
CAMERA_MODE="orbbec"
ORBBEC_WS="${ORBBEC_WS:-${CAMPUSCAR_ROOT}/orbbec_ws}"
ORBBEC_SETUP="${ORBBEC_SETUP:-${ORBBEC_WS}/install/setup.bash}"

# ── rosbridge / RTK ───────────────────────────────────────
ROSBRIDGE_WS="${ROSBRIDGE_WS:-${CAMPUSCAR_ROOT}/src/rtk_tools/rosbridge_ts}"
ROSBRIDGE_SETUP="${ROSBRIDGE_SETUP:-${ROSBRIDGE_WS}/install/setup.bash}"
RTK_BAUD=115200
