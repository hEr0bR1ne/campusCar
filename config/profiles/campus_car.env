# ============================================================
# Hardware profile: current campusCar
# ============================================================

ROBOT_NAME="campus_car"
ROBOT_DESCRIPTION="Current campus car with SSH-launched ROS2 chassis and Orbbec Gemini 330 camera"

# Chassis adapter
CHASSIS_ADAPTER="ssh_ros2_base_control"
CHASSIS_START_MODE="ssh_ros2"
CHASSIS_REQUIRED="1"
CAR_IP="${CAR_IP:-192.168.100.2}"
CAR_USER="${CAR_USER:-bingda}"
CAR_PASS="${CAR_PASS:-}"
CAR_BASE_TYPE="${CAR_BASE_TYPE:-4WD}"
CAR_LAUNCH_CMD="${CAR_LAUNCH_CMD:-export BASE_TYPE=${CAR_BASE_TYPE}; source ~/ros2_ws/install/setup.bash && ros2 launch base_control_ros2 base_control.launch.py}"
CHASSIS_NODE_CHECK_PATTERN="${CHASSIS_NODE_CHECK_PATTERN:-base_control}"
CHASSIS_LOG_FILE="${CHASSIS_LOG_FILE:-~/ros2_base_control.log}"

# Topics exposed by this chassis/camera stack
CMD_VEL_TOPIC="${CMD_VEL_TOPIC:-/cmd_vel}"
FIX_TOPIC="${FIX_TOPIC:-/fix}"
HEADING_TOPIC="${HEADING_TOPIC:-/heading}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/color/image_raw}"
CAMERA_INFO_TOPIC="${CAMERA_INFO_TOPIC:-/camera/color/camera_info}"
IMAGE_TOPIC_ALIASES="${IMAGE_TOPIC_ALIASES:-/camera/color/image_flipped}"

# Camera adapter
CAMERA_ADAPTER="orbbec_gemini_330_ros2"
CAMERA_DEPENDENCY_MODE="orbbec"
CAMERA_START_MODE="ros2_launch"
CAMERA_DRIVER_LABEL="Orbbec Gemini 330"
CAMERA_LAUNCH_PACKAGE="orbbec_camera"
CAMERA_LAUNCH_FILE="gemini_330_series.launch.py"
CAMERA_PROCESS_PATTERN="gemini_330_series.launch.py|[c]omponent_container.*camera_container|orbbec_camera"
CAMERA_USB_RESET_IDS="${CAMERA_USB_RESET_IDS:-2bc5:0807}"

CAMERA_SETUP_FILES=("$ORBBEC_SETUP")
CAMERA_STOP_PATTERNS=(
    "orbbec_camera"
    "gemini_330_series.launch.py"
    "[c]omponent_container.*camera_container"
)
CAMERA_LAUNCH_ARGS=(
    "enable_depth:=${ORBBEC_ENABLE_DEPTH:-false}"
    "enable_point_cloud:=${ORBBEC_ENABLE_POINT_CLOUD:-false}"
    "enable_colored_point_cloud:=${ORBBEC_ENABLE_COLORED_POINT_CLOUD:-false}"
    "enable_frame_sync:=${ORBBEC_ENABLE_FRAME_SYNC:-false}"
    "color_width:=${ORBBEC_COLOR_WIDTH:-1280}"
    "color_height:=${ORBBEC_COLOR_HEIGHT:-720}"
    "color_fps:=${ORBBEC_COLOR_FPS:-10}"
    "color_format:=${ORBBEC_COLOR_FORMAT:-MJPG}"
    "color.image_raw.enable_pub_plugins:=[\"image_transport/raw\"]"
)
