# ============================================================
# campusCar common runtime config
# ============================================================
#
# Hardware-specific chassis/camera settings live in config/profiles/*.env.
# Select a robot with:
#   ROBOT_PROFILE=campus_car ./scripts/launch_all.sh
#   ./scripts/launch_all.sh --profile campus_car
#
# Keep passwords and per-machine overrides in ignored local files:
#   config/profiles/<profile>.local.env
#   config/robot.local.env

_CAMPUSCAR_ENV_FILE="${BASH_SOURCE[0]:-$0}"
CAMPUSCAR_ROOT="${CAMPUSCAR_ROOT:-$(cd "$(dirname "$_CAMPUSCAR_ENV_FILE")/.." && pwd)}"
unset _CAMPUSCAR_ENV_FILE

ROBOT_PROFILE="${ROBOT_PROFILE:-campus_car}"
ROBOT_PROFILE_DIR="${ROBOT_PROFILE_DIR:-${CAMPUSCAR_ROOT}/config/profiles}"
ROBOT_PROFILE_FILE="${ROBOT_PROFILE_FILE:-${ROBOT_PROFILE_DIR}/${ROBOT_PROFILE}.env}"

# Common ROS2 topics
CMD_VEL_TOPIC="${CMD_VEL_TOPIC:-/cmd_vel}"
FIX_TOPIC="${FIX_TOPIC:-/fix}"
HEADING_TOPIC="${HEADING_TOPIC:-/heading}"
IMAGE_TOPIC="${IMAGE_TOPIC:-/camera/color/image_raw}"
CAMERA_INFO_TOPIC="${CAMERA_INFO_TOPIC:-${IMAGE_TOPIC%/*}/camera_info}"
IMAGE_TOPIC_ALIASES="${IMAGE_TOPIC_ALIASES:-}"
UE_COMMAND_TOPIC="${UE_COMMAND_TOPIC:-/U2RTopic_Command}"
RTK_POS_TOPIC="${RTK_POS_TOPIC:-/R2UTopic_Pos}"
RTK_TEXT_TOPIC="${RTK_TEXT_TOPIC:-/R2UTopic_Text}"
RTK_IMAGE_TOPIC="${RTK_IMAGE_TOPIC:-/R2UTopic_Image}"
RTK_IMAGE_IN_TOPIC="${RTK_IMAGE_IN_TOPIC:-}"

# Common motion limits
MAX_LINEAR_SPEED="${MAX_LINEAR_SPEED:-1.0}"
MAX_ANGULAR_SPEED="${MAX_ANGULAR_SPEED:-1.0}"
DEFAULT_LINEAR_SPEED="${DEFAULT_LINEAR_SPEED:-0.3}"
DEFAULT_ANGULAR_SPEED="${DEFAULT_ANGULAR_SPEED:-0.5}"
TANK_TURN_MODE="${TANK_TURN_MODE:-angular}"
TANK_TURN_SIDE_SPEED_SCALE="${TANK_TURN_SIDE_SPEED_SCALE:-1.0}"
TANK_TURN_MIN_SIDE_SPEED="${TANK_TURN_MIN_SIDE_SPEED:-0.10}"
TANK_TURN_MAX_SIDE_SPEED="${TANK_TURN_MAX_SIDE_SPEED:-1.0}"

# Common RTK / rosbridge
RTK_BAUD="${RTK_BAUD:-115200}"
ROSBRIDGE_PORT="${ROSBRIDGE_PORT:-9090}"
UE_PUBLISH_RATE="${UE_PUBLISH_RATE:-1.0}"
RTK_RX_LOG_RATE="${RTK_RX_LOG_RATE:-0}"

# Common UE command bridge / coordinate conversion
UE_DIRECTION_RATE_HZ="${UE_DIRECTION_RATE_HZ:-10}"
UE_DIRECTION_TIMEOUT_SEC="${UE_DIRECTION_TIMEOUT_SEC:-0.8}"
UE_NAV_RATE_HZ="${UE_NAV_RATE_HZ:-10}"
UE_ARRIVE_THRESHOLD_M="${UE_ARRIVE_THRESHOLD_M:-0.5}"
UE_HEADING_KP="${UE_HEADING_KP:-1.2}"
UE_HEADING_TOLERANCE="${UE_HEADING_TOLERANCE:-0.15}"
UE_COORD_MODE="${UE_COORD_MODE:-auto}"
UE_LOCAL_ORIGIN_LAT="${UE_LOCAL_ORIGIN_LAT:-}"
UE_LOCAL_ORIGIN_LON="${UE_LOCAL_ORIGIN_LON:-}"
UE_LOCAL_ORIGIN_X="${UE_LOCAL_ORIGIN_X:-0}"
UE_LOCAL_ORIGIN_Y="${UE_LOCAL_ORIGIN_Y:-0}"
UE_UNITS_PER_METER="${UE_UNITS_PER_METER:-100}"
UE_LOCAL_ROTATION_DEG="${UE_LOCAL_ROTATION_DEG:-0}"
UE_LOCAL_X_SIGN="${UE_LOCAL_X_SIGN:-1}"
UE_LOCAL_Y_SIGN="${UE_LOCAL_Y_SIGN:-1}"

# Common video ports
RTSP_PORT="${RTSP_PORT:-8554}"
HLS_PORT="${HLS_PORT:-8888}"
MJPEG_PORT="${MJPEG_PORT:-8080}"

# Common paths
ROS_DISTRO="${ROS_DISTRO:-humble}"
ROS_SETUP="${ROS_SETUP:-/opt/ros/${ROS_DISTRO}/setup.bash}"
ORBBEC_WS="${ORBBEC_WS:-${CAMPUSCAR_ROOT}/orbbec_ws}"
ORBBEC_SETUP="${ORBBEC_SETUP:-${ORBBEC_WS}/install/setup.bash}"
ROSBRIDGE_WS="${ROSBRIDGE_WS:-${CAMPUSCAR_ROOT}/src/rtk_tools/rosbridge_ts}"
ROSBRIDGE_SETUP="${ROSBRIDGE_SETUP:-${ROSBRIDGE_WS}/install/setup.bash}"

# Adapter defaults. Profiles override these for each robot.
ROBOT_NAME="${ROBOT_NAME:-${ROBOT_PROFILE}}"
CHASSIS_ADAPTER="${CHASSIS_ADAPTER:-none}"
CHASSIS_START_MODE="${CHASSIS_START_MODE:-skip}"       # skip, ssh_ros2, local_command
CHASSIS_REQUIRED="${CHASSIS_REQUIRED:-0}"
CHASSIS_NODE_CHECK_PATTERN="${CHASSIS_NODE_CHECK_PATTERN:-}"
CHASSIS_NODE_CHECK_CMD="${CHASSIS_NODE_CHECK_CMD:-}"
CHASSIS_LOG_FILE="${CHASSIS_LOG_FILE:-~/ros2_chassis.log}"
CAR_IP="${CAR_IP:-}"
CAR_USER="${CAR_USER:-}"
CAR_PASS="${CAR_PASS:-}"
CAR_LAUNCH_CMD="${CAR_LAUNCH_CMD:-}"
LOCAL_CHASSIS_LAUNCH_CMD="${LOCAL_CHASSIS_LAUNCH_CMD:-}"
SUDO_PASS="${SUDO_PASS:-}"

CAMERA_ADAPTER="${CAMERA_ADAPTER:-none}"
CAMERA_DEPENDENCY_MODE="${CAMERA_DEPENDENCY_MODE:-none}" # none, orbbec, custom
CAMERA_START_MODE="${CAMERA_START_MODE:-skip}"           # skip, ros2_launch, command
CAMERA_DRIVER_LABEL="${CAMERA_DRIVER_LABEL:-camera}"
CAMERA_LAUNCH_PACKAGE="${CAMERA_LAUNCH_PACKAGE:-}"
CAMERA_LAUNCH_FILE="${CAMERA_LAUNCH_FILE:-}"
CAMERA_LAUNCH_CMD="${CAMERA_LAUNCH_CMD:-}"
CAMERA_PROCESS_PATTERN="${CAMERA_PROCESS_PATTERN:-}"
CAMERA_USB_RESET_IDS="${CAMERA_USB_RESET_IDS:-}"
CAMERA_REUSE_PROBE_TIMEOUT="${CAMERA_REUSE_PROBE_TIMEOUT:-3}"
CAMERA_FIRST_FRAME_TIMEOUT="${CAMERA_FIRST_FRAME_TIMEOUT:-8}"
REUSE_CAMERA="${REUSE_CAMERA:-1}"
RESET_CAMERA_USB="${RESET_CAMERA_USB:-0}"

HIKROBOT_CAMERA_GUID="${HIKROBOT_CAMERA_GUID:-}"
HIKROBOT_CAMERA_NODE="${HIKROBOT_CAMERA_NODE:-hikrobot_camera}"
HIKROBOT_FRAME_ID="${HIKROBOT_FRAME_ID:-hikrobot_camera}"
HIKROBOT_PIXEL_FORMAT="${HIKROBOT_PIXEL_FORMAT:-BGR8}"
HIKROBOT_WIDTH="${HIKROBOT_WIDTH:-1440}"
HIKROBOT_HEIGHT="${HIKROBOT_HEIGHT:-1080}"
HIKROBOT_FPS="${HIKROBOT_FPS:-30.0}"
HIKROBOT_EXPOSURE_AUTO="${HIKROBOT_EXPOSURE_AUTO:-Continuous}"
HIKROBOT_GAIN_AUTO="${HIKROBOT_GAIN_AUTO:-Continuous}"
HIKROBOT_GEV_PACKET_SIZE="${HIKROBOT_GEV_PACKET_SIZE:-}"
HIKROBOT_VERBOSE="${HIKROBOT_VERBOSE:-false}"
HIKROBOT_ARAVIS_PARAMS_FILE="${HIKROBOT_ARAVIS_PARAMS_FILE:-${CAMPUSCAR_ROOT}/data/logs/hikrobot_aravis_params.yaml}"

CAMERA_SETUP_FILES=()
CAMERA_LAUNCH_ARGS=()
CAMERA_STOP_PATTERNS=()

_ROBOT_PROFILE_LOCAL="${ROBOT_PROFILE_DIR}/${ROBOT_PROFILE}.local.env"
_ROBOT_GLOBAL_LOCAL="${CAMPUSCAR_ROOT}/config/robot.local.env"

if [ -f "$_ROBOT_GLOBAL_LOCAL" ]; then
    # shellcheck disable=SC1090
    source "$_ROBOT_GLOBAL_LOCAL"
fi

if [ -f "$_ROBOT_PROFILE_LOCAL" ]; then
    # shellcheck disable=SC1090
    source "$_ROBOT_PROFILE_LOCAL"
fi

if [ ! -f "$ROBOT_PROFILE_FILE" ]; then
    echo "Robot profile not found: $ROBOT_PROFILE_FILE" >&2
    return 1 2>/dev/null || exit 1
fi

# shellcheck disable=SC1090
source "$ROBOT_PROFILE_FILE"

if [ -f "$_ROBOT_PROFILE_LOCAL" ]; then
    # shellcheck disable=SC1090
    source "$_ROBOT_PROFILE_LOCAL"
fi

if [ -f "$_ROBOT_GLOBAL_LOCAL" ]; then
    # shellcheck disable=SC1090
    source "$_ROBOT_GLOBAL_LOCAL"
fi
unset _ROBOT_PROFILE_LOCAL _ROBOT_GLOBAL_LOCAL

export CAMPUSCAR_ROOT ROBOT_PROFILE ROBOT_NAME
export CMD_VEL_TOPIC FIX_TOPIC HEADING_TOPIC IMAGE_TOPIC CAMERA_INFO_TOPIC IMAGE_TOPIC_ALIASES
export UE_COMMAND_TOPIC RTK_POS_TOPIC RTK_TEXT_TOPIC RTK_IMAGE_TOPIC RTK_IMAGE_IN_TOPIC
export MAX_LINEAR_SPEED MAX_ANGULAR_SPEED DEFAULT_LINEAR_SPEED DEFAULT_ANGULAR_SPEED
export TANK_TURN_MODE TANK_TURN_SIDE_SPEED_SCALE TANK_TURN_MIN_SIDE_SPEED TANK_TURN_MAX_SIDE_SPEED
export RTK_BAUD ROSBRIDGE_PORT UE_PUBLISH_RATE RTK_RX_LOG_RATE
export UE_DIRECTION_RATE_HZ UE_DIRECTION_TIMEOUT_SEC UE_NAV_RATE_HZ UE_ARRIVE_THRESHOLD_M
export UE_HEADING_KP UE_HEADING_TOLERANCE UE_COORD_MODE UE_LOCAL_ORIGIN_LAT UE_LOCAL_ORIGIN_LON
export UE_LOCAL_ORIGIN_X UE_LOCAL_ORIGIN_Y UE_UNITS_PER_METER UE_LOCAL_ROTATION_DEG
export UE_LOCAL_X_SIGN UE_LOCAL_Y_SIGN
export RTSP_PORT HLS_PORT MJPEG_PORT
export ROS_DISTRO ROS_SETUP ORBBEC_WS ORBBEC_SETUP ROSBRIDGE_WS ROSBRIDGE_SETUP
export CHASSIS_ADAPTER CHASSIS_START_MODE CHASSIS_REQUIRED CHASSIS_NODE_CHECK_PATTERN
export CHASSIS_NODE_CHECK_CMD CHASSIS_LOG_FILE CAR_IP CAR_USER CAR_PASS CAR_LAUNCH_CMD
export LOCAL_CHASSIS_LAUNCH_CMD SUDO_PASS
export CAMERA_ADAPTER CAMERA_DEPENDENCY_MODE CAMERA_START_MODE CAMERA_DRIVER_LABEL
export CAMERA_LAUNCH_PACKAGE CAMERA_LAUNCH_FILE CAMERA_LAUNCH_CMD CAMERA_PROCESS_PATTERN
export CAMERA_USB_RESET_IDS CAMERA_REUSE_PROBE_TIMEOUT CAMERA_FIRST_FRAME_TIMEOUT
export REUSE_CAMERA RESET_CAMERA_USB
export HIKROBOT_CAMERA_GUID HIKROBOT_CAMERA_NODE HIKROBOT_FRAME_ID HIKROBOT_PIXEL_FORMAT
export HIKROBOT_WIDTH HIKROBOT_HEIGHT HIKROBOT_FPS HIKROBOT_EXPOSURE_AUTO HIKROBOT_GAIN_AUTO
export HIKROBOT_GEV_PACKET_SIZE HIKROBOT_VERBOSE HIKROBOT_ARAVIS_PARAMS_FILE
