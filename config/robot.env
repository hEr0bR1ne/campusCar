# ============================================================
# campusCar 机器人配置文件
# 换车时只需修改这一个文件
# ============================================================

_CAMPUSCAR_ENV_FILE="${BASH_SOURCE[0]:-$0}"
CAMPUSCAR_ROOT="${CAMPUSCAR_ROOT:-$(cd "$(dirname "$_CAMPUSCAR_ENV_FILE")/.." && pwd)}"
unset _CAMPUSCAR_ENV_FILE

# ── 底盘网络 ──────────────────────────────────────────────
CAR_IP="192.168.100.2"
CAR_USER="bingda"
CAR_PASS="bingda"
SUDO_PASS="1"
CAR_BASE_TYPE="4WD"

# ── ROS2 话题 ─────────────────────────────────────────────
CMD_VEL_TOPIC="/cmd_vel"
FIX_TOPIC="/fix"
HEADING_TOPIC="/heading"
IMAGE_TOPIC="/camera/color/image_raw"
CAMERA_INFO_TOPIC="/camera/color/camera_info"
UE_COMMAND_TOPIC="/U2RTopic_Command"
RTK_POS_TOPIC="/R2UTopic_Pos"
RTK_TEXT_TOPIC="/R2UTopic_Text"
RTK_IMAGE_TOPIC="/R2UTopic_Image"
RTK_IMAGE_IN_TOPIC=""

# ── 速度限制 ──────────────────────────────────────────────
MAX_LINEAR_SPEED=1.0      # m/s
MAX_ANGULAR_SPEED=1.0     # rad/s
DEFAULT_LINEAR_SPEED=0.3  # m/s（GUI 默认值）
DEFAULT_ANGULAR_SPEED=0.5 # rad/s（GUI 默认值）
TANK_TURN_MODE=angular          # angular=零线速度原地转；experimental_xz=实验性 X/Z 反向混控
TANK_TURN_SIDE_SPEED_SCALE=1.0  # 仅 experimental_xz 使用
TANK_TURN_MIN_SIDE_SPEED=0.10   # 仅 experimental_xz 使用
TANK_TURN_MAX_SIDE_SPEED=1.0    # 仅 experimental_xz 使用

# ── 底盘启动命令（远程 SSH）────────────────────────────────
# 不同底盘修改这里
CAR_LAUNCH_CMD="export BASE_TYPE=${CAR_BASE_TYPE}; source ~/ros2_ws/install/setup.bash && ros2 launch base_control_ros2 base_control.launch.py"

# ── 串口 / RTK ────────────────────────────────────────────
RTK_BAUD=115200
ROSBRIDGE_PORT=9090
UE_PUBLISH_RATE=1.0      # Hz，发给 UE 的 /R2UTopic_Pos 固定 1 秒一次
RTK_RX_LOG_RATE=0        # Hz，0 表示不打印不均匀的原始 /fix 接收日志

# ── UE 指令桥接 / 坐标转换 ─────────────────────────────────
UE_DIRECTION_RATE_HZ=10        # Hz，UE 方向指令持续补发频率
UE_DIRECTION_TIMEOUT_SEC=0.8   # 秒，超过该时间没收到新的方向指令就自动停车
UE_NAV_RATE_HZ=10              # Hz，坐标导航控制频率
UE_ARRIVE_THRESHOLD_M=0.5      # 米，到达目标判定阈值
UE_HEADING_KP=1.2              # 坐标导航转向比例
UE_HEADING_TOLERANCE=0.15      # rad，朝向误差容忍
UE_COORD_MODE=auto             # auto/gps/local；UE 若发场景坐标，建议改 local
UE_LOCAL_ORIGIN_LAT=""         # UE 本地坐标原点对应的纬度
UE_LOCAL_ORIGIN_LON=""         # UE 本地坐标原点对应的经度
UE_LOCAL_ORIGIN_X=0            # UE 场景中原点锚点的 X
UE_LOCAL_ORIGIN_Y=0            # UE 场景中原点锚点的 Y
UE_UNITS_PER_METER=100         # UE 单位到米；UE 默认 100 cm = 1 m
UE_LOCAL_ROTATION_DEG=0        # UE +X 相对 ENU 正东的逆时针角度
UE_LOCAL_X_SIGN=1              # X 轴方向反了就设为 -1
UE_LOCAL_Y_SIGN=1              # Y 轴方向反了就设为 -1

# ── 视频流端口 ────────────────────────────────────────────
RTSP_PORT=8554
HLS_PORT=8888
MJPEG_PORT=8080

# ── 相机适配 ──────────────────────────────────────────────
# CAMERA_MODE:
#   orbbec                当前车的 Orbbec 深度相机
#   hikrobot_gige_aravis  海康 MV-CS016-10GC 等 GigE Vision/GenICam 工业相机
#   none                  不启动相机节点，只保留视频/GUI 等消费者
CAMERA_MODE="${CAMERA_MODE:-orbbec}"

# 海康 MV-CS016-10GC / camera_aravis2 参数；相机到货后可用 IP 或 camera_finder 输出的 GUID 固定设备。
HIKROBOT_CAMERA_GUID="${HIKROBOT_CAMERA_GUID:-}"
HIKROBOT_CAMERA_NODE="${HIKROBOT_CAMERA_NODE:-hikrobot_camera}"
HIKROBOT_FRAME_ID="${HIKROBOT_FRAME_ID:-hikrobot_camera}"
HIKROBOT_PIXEL_FORMAT="${HIKROBOT_PIXEL_FORMAT:-BGR8}"
HIKROBOT_WIDTH="${HIKROBOT_WIDTH:-1440}"
HIKROBOT_HEIGHT="${HIKROBOT_HEIGHT:-1080}"
HIKROBOT_FPS="${HIKROBOT_FPS:-30.0}"
HIKROBOT_EXPOSURE_AUTO="${HIKROBOT_EXPOSURE_AUTO:-Continuous}"
HIKROBOT_GAIN_AUTO="${HIKROBOT_GAIN_AUTO:-Continuous}"
HIKROBOT_GEV_PACKET_SIZE="${HIKROBOT_GEV_PACKET_SIZE:-}"
HIKROBOT_VERBOSE="${HIKROBOT_VERBOSE:-false}"

# ── 系统路径 ──────────────────────────────────────────────
ROS_DISTRO="${ROS_DISTRO:-humble}"
ROS_SETUP="${ROS_SETUP:-/opt/ros/${ROS_DISTRO}/setup.bash}"
ORBBEC_WS="${ORBBEC_WS:-${CAMPUSCAR_ROOT}/orbbec_ws}"
ORBBEC_SETUP="${ORBBEC_SETUP:-${ORBBEC_WS}/install/setup.bash}"
ROSBRIDGE_WS="${ROSBRIDGE_WS:-${CAMPUSCAR_ROOT}/src/rtk_tools/rosbridge_ts}"
ROSBRIDGE_SETUP="${ROSBRIDGE_SETUP:-${ROSBRIDGE_WS}/install/setup.bash}"
