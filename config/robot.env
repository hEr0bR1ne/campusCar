# ============================================================
# campusCar 机器人配置文件 — 骨架
#
# 本文件只包含：
#   1. 路径计算
#   2. 车型 profile 加载机制
#   3. 所有模块共用的 ROS2 话题名和服务端口
#   4. 不随车型变化的运行时参数
#
# 车型特定内容（底盘网络、速度、相机、路径等）全部在：
#   config/profiles/<CAR_PROFILE>.env
#
# 换车：修改 CAR_PROFILE 或在启动时 export CAR_PROFILE=<name>
# ============================================================

_CAMPUSCAR_ENV_FILE="${BASH_SOURCE[0]:-$0}"
CAMPUSCAR_ROOT="${CAMPUSCAR_ROOT:-$(cd "$(dirname "$_CAMPUSCAR_ENV_FILE")/.." && pwd)}"
CAMPUSCAR_CONFIG_DIR="${CAMPUSCAR_CONFIG_DIR:-${CAMPUSCAR_ROOT}/config}"
CAMPUSCAR_PROFILE_DIR="${CAMPUSCAR_PROFILE_DIR:-${CAMPUSCAR_CONFIG_DIR}/profiles}"
CAR_PROFILE="${CAR_PROFILE:-old-orange-pi-orbbec}"
CAR_PROFILE_FILE="${CAR_PROFILE_FILE:-${CAMPUSCAR_PROFILE_DIR}/${CAR_PROFILE}.env}"
unset _CAMPUSCAR_ENV_FILE

# ── ROS2 话题（接口约定，不随车型变）────────────────────────
CMD_VEL_TOPIC="/cmd_vel"
FIX_TOPIC="/fix"
HEADING_TOPIC="/heading"
IMU_TOPIC="/imu"
ODOM_TOPIC="/odom"
IMAGE_TOPIC="/camera/color/image_raw"
CAMERA_INFO_TOPIC="/camera/color/camera_info"
UE_COMMAND_TOPIC="/U2RTopic_Command"
RTK_POS_TOPIC="/R2UTopic_Pos"
RTK_TEXT_TOPIC="/R2UTopic_Text"
RTK_IMAGE_TOPIC="/R2UTopic_Image"
RTK_IMAGE_IN_TOPIC=""

# ── 服务端口（和车型无关）────────────────────────────────────
RTSP_PORT=8554
HLS_PORT=8888
MJPEG_PORT=8080
WEB_GUI_PORT="${WEB_GUI_PORT:-8088}"
WEB_CONTROL_RATE_HZ="${WEB_CONTROL_RATE_HZ:-20}"
WEB_CONTROL_TIMEOUT_SEC="${WEB_CONTROL_TIMEOUT_SEC:-0.45}"
ROSBRIDGE_PORT=9090

# ── RTK / UE 发布（通用节奏参数）────────────────────────────
UE_PUBLISH_RATE=1.0      # Hz，发给 UE 的 /R2UTopic_Pos 固定频率
RTK_RX_LOG_RATE=0        # Hz，0 表示不打印原始 /fix 接收日志

# ── UE 坐标转换（通用，具体原点在 profile 里覆盖）────────────
UE_COORD_MODE=auto             # auto/gps/local
UE_LOCAL_ORIGIN_LAT=""
UE_LOCAL_ORIGIN_LON=""
UE_LOCAL_ORIGIN_X=0
UE_LOCAL_ORIGIN_Y=0
UE_UNITS_PER_METER=100
UE_LOCAL_ROTATION_DEG=0
UE_LOCAL_X_SIGN=1
UE_LOCAL_Y_SIGN=1

# ── ROS 环境（可被 profile 覆盖）─────────────────────────────
ROS_DISTRO="${ROS_DISTRO:-humble}"
ROS_SETUP="${ROS_SETUP:-/opt/ros/${ROS_DISTRO}/setup.bash}"

# ── 加载车型 Profile ──────────────────────────────────────────
if [ -f "$CAR_PROFILE_FILE" ]; then
    # shellcheck disable=SC1090
    source "$CAR_PROFILE_FILE"
elif [ -n "${CAR_PROFILE_FILE:-}" ]; then
    echo "[campusCar] 警告：未找到车型 profile 文件: $CAR_PROFILE_FILE" >&2
fi
